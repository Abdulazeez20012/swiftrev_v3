const TransactionRow: React.FC<RecItem> = ({ id, date, amount, source, status }) => (
    <div className="p-4 flex items-center justify-between group hover:bg-gray-50/50 dark:hover:bg-slate-800/50 transition-colors">
        <div className="flex items-center gap-4">
            <div className={`p-2 rounded-full ${status === 'matched' ? 'bg-emerald-100 text-emerald-600' :
                status === 'discrepancy' ? 'bg-rose-100 text-rose-600' :
                    'bg-gray-100 text-gray-600'
                }`}>
                {status === 'matched' ? <CheckCircle2 size={16} /> :
                    status === 'discrepancy' ? <AlertCircle size={16} /> :
                        <ArrowRightLeft size={16} />}
            </div>
            <div>
                <p className="font-bold text-slate-900 dark:text-slate-100">{source}</p>
                <p className="text-xs text-slate-500 uppercase tracking-tight">{id} • {date}</p>
            </div>
        </div>
        <div className="text-right">
            <p className="font-bold text-slate-900 dark:text-slate-100">₦{amount.toLocaleString(undefined, { minimumFractionDigits: 2 })}</p>
            <p className={`text-[10px] font-bold uppercase tracking-wider ${status === 'matched' ? 'text-emerald-500' :
                status === 'discrepancy' ? 'text-rose-500' :
                    'text-gray-400'
                }`}>{status}</p>
        </div>
    </div>
);
