                            Resolve Manually
                        </button>
                        <button className="px-4 py-2 bg-white dark:bg-slate-900 text-rose-600 border border-rose-200 dark:border-rose-900/50 rounded-lg text-sm font-medium hover:bg-rose-50 transition-colors">
                            Ignore for now
                        </button>
                    </div>
                </div>
            </div>
        </div>
