import React from 'react';
import { Search, Filter, CheckCircle2, AlertCircle, ArrowRightLeft } from 'lucide-react';

interface RecItem {
    id: string;
    date: string;
    amount: number;
    source: string;
    status: 'matched' | 'discrepancy' | 'pending';
}

export const Reconciliation: React.FC = () => {

    return (
        <div className="space-y-8">
            <div className="flex justify-between items-end">
                <div>
                    <h2 className="text-3xl font-bold tracking-tight text-slate-900 dark:text-slate-50">Financial Reconciliation</h2>
                    <p className="text-slate-500 dark:text-slate-400">Match bank statements with internal ledger entries.</p>
                </div>
                <div className="flex gap-3">
                    <button className="px-4 py-2 bg-white dark:bg-slate-900 border border-gray-200 dark:border-slate-800 rounded-lg text-sm font-medium flex items-center gap-2 hover:bg-gray-50 transition-colors">
                        <Filter size={16} /> Filter
                    </button>
                    <button className="px-4 py-2 bg-primary text-white rounded-lg text-sm font-medium flex items-center gap-2 hover:bg-primary/90 transition-colors shadow-sm">
                        Run Auto-Match
                    </button>
                </div>
            </div>

            <div className="grid grid-cols-1 lg:grid-cols-2 gap-8">
                {/* Left Side: Hospital Ledger */}
                <div className="bg-white dark:bg-slate-900 rounded-2xl border border-gray-200 dark:border-slate-800 shadow-sm overflow-hidden text-sm">
                    <div className="p-4 border-b border-gray-100 dark:border-slate-800 bg-gray-50/50 dark:bg-slate-900/50 flex justify-between items-center">
                        <span className="font-semibold px-2">Hospital Ledger Entries</span>
                        <div className="relative">
                            <Search className="absolute left-3 top-1/2 -translate-y-1/2 text-gray-400" size={14} />
                            <input
                                type="text"
                                placeholder="Search ledger..."
                                className="pl-9 pr-4 py-1.5 bg-white dark:bg-slate-800 border-none rounded-md text-xs focus:ring-1 focus:ring-primary w-48"
                            />
                        </div>
                    </div>
                    <div className="divide-y divide-gray-100 dark:divide-slate-800">
                        <TransactionRow
                            id="L-9021"
                            date="2026-02-11"
                            amount={450.00}
                            source="Patient: John Doe"
                            status="matched"
                        />
                        <TransactionRow
                            id="L-9022"
                            date="2026-02-11"
                            amount={1200.00}
                            source="Patient: Jane Smith"
                            status="discrepancy"
                        />
                        <TransactionRow
                            id="L-9023"
                            date="2026-02-10"
                            amount={85.00}
                            source="Pharmacy: Dispense #12"
                            status="pending"
                        />
                    </div>
                </div>

                {/* Right Side: Bank Statement */}
                <div className="bg-white dark:bg-slate-900 rounded-2xl border border-gray-200 dark:border-slate-800 shadow-sm overflow-hidden text-sm">
                    <div className="p-4 border-b border-gray-100 dark:border-slate-800 bg-gray-50/50 dark:bg-slate-900/50 flex justify-between items-center">
                        <span className="font-semibold px-2">Bank Records (API)</span>
                        <span className="text-[10px] bg-emerald-100 text-emerald-700 px-2 py-0.5 rounded-full font-bold uppercase tracking-wider">Connected</span>
                    </div>
                    <div className="divide-y divide-gray-100 dark:divide-slate-800">
                        <TransactionRow
                            id="B-782"
                            date="2026-02-11"
                            amount={450.00}
                            source="SwiftPay: Ref 0921"
                            status="matched"
                        />
                        <TransactionRow
                            id="B-783"
                            date="2026-02-11"
                            amount={1150.00}
                            source="Wire Trans: SMTH_JN"
                            status="discrepancy"
                        />
                        <TransactionRow
                            id="B-784"
                            date="2026-02-11"
                            amount={200.00}
                            source="ATM Deposit"
                            status="pending"
                        />
                    </div>
                </div>
            </div>

            {/* Discrepancy Highlight */}
            <div className="bg-rose-50 dark:bg-rose-950/20 border border-rose-200 dark:border-rose-900/50 p-6 rounded-2xl flex items-start gap-4">
                <div className="p-3 bg-rose-100 dark:bg-rose-900/50 text-rose-600 dark:text-rose-400 rounded-xl">
                    <AlertCircle size={24} />
                </div>
                <div className="flex-1">
                    <h4 className="text-rose-900 dark:text-rose-100 font-bold mb-1">Unresolved Discrepancy Found</h4>
                    <p className="text-rose-700 dark:text-rose-400 text-sm mb-4">
                        Hospital record L-9022 (₦1,200.00) does not match Bank record B-783 (₦1,150.00).
                        There is a ₦50 shortage in the bank deposit.
                    </p>
                    <div className="flex gap-2">
