import React from 'react';
import { Plus, Search, MoreVertical, Building2, MapPin, Users } from 'lucide-react';

interface Hospital {
    id: string;
    name: string;
    location: string;
    staffCount: number;
    revenue: string;
    status: 'active' | 'onboarding';
}

const hospitals: Hospital[] = [
    { id: '1', name: 'City General Hospital', location: 'Lagos Island', staffCount: 150, revenue: '₦24.5M', status: 'active' },
    { id: '2', name: 'Lagos University Teaching Hospital (LUTH)', location: 'Idi-Araba', staffCount: 1200, revenue: '₦142.8M', status: 'active' },
    { id: '3', name: 'Evercare Hospital', location: 'Lekki Phase 1', staffCount: 300, revenue: '₦85.2M', status: 'active' },
    { id: '4', name: 'Reddington Hospital', location: 'Victoria Island', staffCount: 450, revenue: '₦62.1M', status: 'onboarding' },
];

export const HospitalManagement: React.FC = () => {
    return (
        <div className="space-y-8">
            <div className="flex justify-between items-end">
                <div>
                    <h2 className="text-3xl font-bold tracking-tight text-slate-900 dark:text-slate-50">Hospital Management</h2>
                    <p className="text-slate-500 dark:text-slate-400">Manage registered hospitals and administrative staff.</p>
                </div>
                <button className="px-4 py-2 bg-primary text-white rounded-lg text-sm font-medium flex items-center gap-2 hover:bg-primary/90 transition-colors shadow-sm">
                    <Plus size={18} /> Add New Hospital
                </button>
            </div>

            <div className="bg-white dark:bg-slate-900 rounded-2xl border border-gray-200 dark:border-slate-800 shadow-sm overflow-hidden">
                <div className="p-4 border-b border-gray-100 dark:border-slate-800 flex justify-between items-center">
                    <div className="relative">
                        <Search className="absolute left-3 top-1/2 -translate-y-1/2 text-gray-400" size={16} />
                        <input
                            type="text"
                            placeholder="Search hospitals..."
                            className="pl-10 pr-4 py-2 bg-gray-50 dark:bg-slate-800 border-none rounded-lg text-sm focus:ring-2 focus:ring-primary w-64"
                        />
                    </div>
                </div>

                <div className="overflow-x-auto">
                    <table className="w-full text-left">
                        <thead>
                            <tr className="bg-gray-50/50 dark:bg-slate-900/50 text-xs font-bold text-slate-500 dark:text-slate-400 uppercase tracking-wider">
                                <th className="px-6 py-4">Hospital Name</th>
                                <th className="px-6 py-4">Location</th>
                                <th className="px-6 py-4">Staff</th>
                                <th className="px-6 py-4">Est. Revenue</th>
                                <th className="px-6 py-4">Status</th>
                                <th className="px-6 py-4 text-right">Actions</th>
                            </tr>
                        </thead>
                        <tbody className="divide-y divide-gray-100 dark:divide-slate-800">
                            {hospitals.map((hospital) => (
                                <tr key={hospital.id} className="group hover:bg-gray-50/50 dark:hover:bg-slate-800/50 transition-colors">
                                    <td className="px-6 py-4">
                                        <div className="flex items-center gap-3">
                                            <div className="p-2 bg-primary/10 text-primary rounded-lg">
                                                <Building2 size={18} />
                                            </div>
                                            <span className="font-semibold text-slate-900 dark:text-slate-100">{hospital.name}</span>
                                        </div>
                                    </td>
                                    <td className="px-6 py-4">
                                        <div className="flex items-center gap-2 text-slate-500 dark:text-slate-400">
                                            <MapPin size={14} />
                                            {hospital.location}
                                        </div>
                                    </td>
                                    <td className="px-6 py-4">
                                        <div className="flex items-center gap-2 text-slate-500 dark:text-slate-400">
                                            <Users size={14} />
                                            {hospital.staffCount}
                                        </div>
                                    </td>
                                    <td className="px-6 py-4 font-bold text-slate-700 dark:text-slate-300">
                                        {hospital.revenue}
                                    </td>
                                    <td className="px-6 py-4">
                                        <span className={`px-2 py-1 rounded-full text-[10px] font-bold uppercase tracking-wider ${hospital.status === 'active'
                                                ? 'bg-emerald-100 text-emerald-700'
                                                : 'bg-amber-100 text-amber-700'
                                            }`}>
                                            {hospital.status}
                                        </span>
                                    </td>
                                    <td className="px-6 py-4 text-right">
                                        <button className="p-2 text-gray-400 hover:text-slate-900 dark:hover:text-slate-100">
                                            <MoreVertical size={18} />
                                        </button>
                                    </td>
                                </tr>
                            ))}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    );
};
