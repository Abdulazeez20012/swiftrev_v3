import React from 'react';
import { DollarSign, ArrowUpRight, ArrowDownRight, Users, Activity } from 'lucide-react';
import { AreaChart, Area, XAxis, YAxis, CartesianGrid, Tooltip, ResponsiveContainer } from 'recharts';

const data = [
    { name: 'Mon', revenue: 4000 },
    { name: 'Tue', revenue: 3000 },
    { name: 'Wed', revenue: 5000 },
    { name: 'Thu', revenue: 2780 },
    { name: 'Fri', revenue: 6890 },
    { name: 'Sat', revenue: 2390 },
    { name: 'Sun', revenue: 3490 },
];

import { useDataService } from '../hooks/useDataService';

export const Dashboard: React.FC = () => {
    const dataService = useDataService();
    const [stats, setStats] = React.useState({
        totalRevenue: 0,
        outstanding: 0,
        patientCount: 0,
        successRate: 100
    });

    React.useEffect(() => {
        const unsub = dataService.treatments().subscribe(async (treatments) => {
            const patientResp = await dataService.patients().getAll();
            const patients = patientResp.data || [];

            const totalRevenue = treatments
                .filter(t => t.status === 'paid')
                .reduce((acc, t) => acc + t.costNaira, 0);

            const outstanding = treatments
                .filter(t => t.status === 'pending')
                .reduce((acc, t) => acc + t.costNaira, 0);

            setStats({
                totalRevenue,
                outstanding,
                patientCount: patients.length,
                successRate: treatments.length > 0
                    ? (treatments.filter(t => t.status === 'paid').length / treatments.length) * 100
                    : 100
            });
        });
        return unsub;
    }, []);

    return (
        <div className="space-y-8">
            <div>
                <h2 className="text-3xl font-bold tracking-tight text-slate-900 dark:text-slate-50">Revenue Oversight</h2>
                <p className="text-slate-500 dark:text-slate-400">Manage hospital performance and revenue cycles.</p>
            </div>

            <div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
                <StatCard
                    title="Total Revenue"
                    value={`₦${stats.totalRevenue.toLocaleString()}`}
                    change="+0%"
                    trend="up"
                    icon={<DollarSign />}
                />
                <StatCard
                    title="Outstanding"
                    value={`₦${stats.outstanding.toLocaleString()}`}
                    change="+0%"
                    trend="up"
                    icon={<Activity />}
                />
                <StatCard
                    title="Total Patients"
                    value={stats.patientCount.toString()}
                    change="+0"
                    trend="up"
                    icon={<Users />}
                />
                <StatCard
                    title="Collection Rate"
                    value={`${stats.successRate.toFixed(1)}%`}
                    change="+0%"
                    trend="up"
                    icon={<ArrowUpRight />}
                />
            </div>

            <div className="bg-white dark:bg-slate-900 p-6 rounded-2xl border border-gray-200 dark:border-slate-800 shadow-sm">
                <h3 className="text-lg font-semibold mb-6">Weekly Revenue Trend</h3>
                <div className="h-[300px] w-full">
                    <ResponsiveContainer width="100%" height="100%">
                        <AreaChart data={data}>
                            <defs>
                                <linearGradient id="colorRev" x1="0" y1="0" x2="0" y2="1">
                                    <stop offset="5%" stopColor="#3b82f6" stopOpacity={0.1} />
                                    <stop offset="95%" stopColor="#3b82f6" stopOpacity={0} />
                                </linearGradient>
                            </defs>
                            <CartesianGrid strokeDasharray="3 3" vertical={false} stroke="#e2e8f0" />
                            <XAxis dataKey="name" axisLine={false} tickLine={false} tick={{ fill: '#64748b', fontSize: 12 }} />
                            <YAxis axisLine={false} tickLine={false} tick={{ fill: '#64748b', fontSize: 12 }} />
                            <Tooltip />
                            <Area type="monotone" dataKey="revenue" stroke="#3b82f6" fillOpacity={1} fill="url(#colorRev)" strokeWidth={3} />
                        </AreaChart>
                    </ResponsiveContainer>
                </div>
            </div>
        </div>
    );
};

const StatCard: React.FC<{ title: string; value: string; change: string; trend: 'up' | 'down'; icon: React.ReactNode }> = ({ title, value, change, trend, icon }) => (
    <div className="bg-white dark:bg-slate-900 p-6 rounded-2xl border border-gray-200 dark:border-slate-800 shadow-sm relative overflow-hidden group hover:border-primary/50 transition-all">
        <div className="flex justify-between items-start mb-4">
            <div className="p-3 bg-gray-50 dark:bg-slate-800 rounded-xl text-slate-600 dark:text-slate-300 group-hover:bg-primary/10 group-hover:text-primary transition-colors">
                {React.cloneElement(icon as React.ReactElement, { size: 24 })}
            </div>
            <div className={`flex items-center text-xs font-medium ${trend === 'up' ? 'text-emerald-500' : 'text-rose-500'}`}>
                {change}
                {trend === 'up' ? <ArrowUpRight size={14} className="ml-1" /> : <ArrowDownRight size={14} className="ml-1" />}
            </div>
        </div>
        <div>
            <p className="text-sm text-slate-500 dark:text-slate-400">{title}</p>
            <p className="text-2xl font-bold text-slate-900 dark:text-slate-50">{value}</p>
        </div>
    </div>
);
